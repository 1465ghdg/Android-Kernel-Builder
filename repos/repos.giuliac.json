[
  {
    "kernelSource": {
      "name": "LineageKernel-KernelSU-Next",
      "repo": "https://github.com/LineageOS/android_kernel_oneplus_sm8650",
      "branch": "lineage-23.2",
      "device": "giuliac",
      "defconfig": "defconfig"
    },
    "kernelSU": {
      "withKernelSU": true,
      "kernelSUFork": "KernelSU-Next"
    },
    "toolchains": [
      {
        "repo": "https://github.com/TheMuppets/proprietary_vendor_oneplus_sm8650-common",
        "branch": "lineage-23.2",
        "name": "proprietary_vendor"
      },
      {
        "repo": "https://github.com/LineageOS/android_prebuilts_clang_kernel_linux-x86_clang-r416183b",
        "branch": "lineage-20.0",
        "name": "clang"
      }
    ],
    "ccache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "externalCommand": {
        "CROSS_COMPILE": "aarch64-linux-gnu-",
        "CROSS_COMPILE_ARM32": "arm-linux-gnueabi-",
        "CROSS_COMPILE_COMPAT": "arm-linux-gnueabi-",
        "CLANG_TRIPLE": "aarch64-linux-gnu-"
      }
    },
    "AnyKernel3": {
      "use": false,
      "release": false,
      "repo": "https://github.com/KernelSU-Next/AnyKernel3",
      "branch": "master"
    },
    "bootImg": {
      "use": true,
      "url": "https://mirrorbits.lineageos.org/full/giuliac/20260609/boot.img",
      "release": true
    }
  }
